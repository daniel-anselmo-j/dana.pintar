# MongoDB Connection String
# Ganti <password> dengan password MongoDB Atlas Anda
MONGO_URI=mongodb+srv://danapintar:danapintar.id@cluster0.s76bgmg.mongodb.net/danapintar?appName=Cluster0

# JWT Secret — ganti dengan string acak yang panjang
